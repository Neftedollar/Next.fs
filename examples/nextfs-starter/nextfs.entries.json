{
  "entries": [
    {
      "from": "./.fable/Proxy.js",
      "to": "./proxy.js",
      "named": ["proxy", "config"]
    },
    {
      "from": "./.fable/Instrumentation.js",
      "to": "./instrumentation.js",
      "named": ["register", "onRequestError"]
    },
    {
      "from": "./.fable/InstrumentationClient.js",
      "to": "./instrumentation-client.js",
      "exportAll": true
    },
    {
      "from": "./.fable/App.Default.js",
      "to": "./app/default.js",
      "default": true
    },
    {
      "directive": "use client",
      "from": "./.fable/App.Error.js",
      "to": "./app/error.js",
      "default": true
    },
    {
      "directive": "use client",
      "from": "./.fable/App.GlobalError.js",
      "to": "./app/global-error.js",
      "default": true
    },
    {
      "from": "./.fable/App.GlobalNotFound.js",
      "to": "./app/global-not-found.js",
      "default": true,
      "named": ["metadata"]
    },
    {
      "from": "./.fable/App.Loading.js",
      "to": "./app/loading.js",
      "default": true
    },
    {
      "from": "./.fable/App.Layout.js",
      "to": "./app/layout.js",
      "default": true,
      "named": ["metadata", "viewport"]
    },
    {
      "from": "./.fable/App.NotFound.js",
      "to": "./app/not-found.js",
      "default": true
    },
    {
      "directive": "use client",
      "from": "./.fable/App.Page.js",
      "to": "./app/page.js",
      "default": true
    },
    {
      "from": "./.fable/App.Template.js",
      "to": "./app/template.js",
      "default": true
    },
    {
      "from": "./.fable/App.Forbidden.js",
      "to": "./app/forbidden.js",
      "default": true
    },
    {
      "from": "./.fable/App.Unauthorized.js",
      "to": "./app/unauthorized.js",
      "default": true
    },
    {
      "directive": "use client",
      "from": "./.fable/App.ClientCounter.js",
      "to": "./app/components/client-counter.js",
      "default": true
    },
    {
      "directive": "use server",
      "from": "./.fable/App.Actions.js",
      "to": "./app/actions.js",
      "named": ["createPost"]
    },
    {
      "from": "./.fable/App.Api.Posts.js",
      "to": "./app/api/posts/route.js",
      "named": ["GET", "POST", "runtime", "preferredRegion", "maxDuration"]
    }
  ]
}
