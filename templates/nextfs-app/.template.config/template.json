{
  "$schema": "http://json.schemastore.org/template",
  "author": "Roman Melnikov",
  "classifications": ["F#", "Web", "Fable", "Next.js", "React"],
  "identity": "NextFs.App",
  "name": "NextFs App Router Application",
  "shortName": "nextfs",
  "description": "A Next.js App Router application written in F# with Fable, NextFs, and NextFs.Dsl computation expressions.",
  "tags": {
    "language": "F#",
    "type": "project"
  },
  "sourceName": "NextFsApp",
  "preferNameDirectory": true,
  "primaryOutputs": [
    { "path": "src/NextFsApp.fsproj" }
  ],
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            ".fable/**",
            ".next/**",
            "node_modules/**",
            "**/bin/**",
            "**/obj/**"
          ]
        }
      ]
    }
  ],
  "postActions": [
    {
      "condition": true,
      "description": "Restore NuGet packages",
      "manualInstructions": [{ "text": "Run 'dotnet restore'" }],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ]
}
